{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/router" },
    { "source": "/(.*)\\.(.*)", "destination": "/$1.$2" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/monitoring/cron/mark-offline",
      "schedule": "0 0 * * *"
    }
  ]
}
